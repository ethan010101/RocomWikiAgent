OPENAI_API_BASE=https://api.longcat.chat/openai
OPENAI_API_KEY=your_longcat_api_key_here
OPENAI_MODEL_NAME=LongCat-Flash-Thinking-2601
# DeepSeek 官方：https://api.deepseek.com
# 思考模式（reasoning_content + content）见：https://api-docs.deepseek.com/zh-cn/guides/thinking_mode
# 方式 A：专用推理模型
# OPENAI_MODEL_NAME=deepseek-reasoner
# 方式 B：deepseek-chat + 开启思考（OpenAI SDK 通过 extra_body 传参，本项目已接好）
# OPENAI_MODEL_NAME=deepseek-chat
# DEEPSEEK_THINKING=true
# OPENAI_API_KEY=sk-...
# 网页展示思考过程请用 POST /chat/stream；SDK 直连：auto | true | false
# RAG_STREAM_OPENAI_SDK=auto
# 与 import_lkwiki / import_pets 一致，无尾斜杠亦可
WIKI_BASE_URL=https://wiki.biligame.com/rocom
# 默认 {WIKI_BASE_URL}/api.php，一般不用改
# WIKI_API_URL=https://wiki.biligame.com/rocom/api.php
# all = 全站列表 + import_lkwiki 命名空间规则；pets = 仅宠物相关（import_pets 规则）
WIKI_MODE=all
# 0 表示不限制；否则只处理前 N 个标题（按 API 顺序）
# WIKI_MAX_PAGES=500
# 正文短于该长度不入库；默认 60
# WIKI_MIN_TEXT_LEN=60
# WIKI_REQUEST_TIMEOUT=30
# 每个标题 parse/请求间隔（秒），减轻 api 压力
# WIKI_PARSE_DELAY=0.05
# HTTP 适配器重试次数、退避、allpages 单页失败时的额外重试次数
# WIKI_HTTP_RETRIES=5
# WIKI_RETRY_BACKOFF=0.7
# WIKI_LIST_RETRY=4

# 只读：指定从哪份 raw_pages.jsonl 做 --from-raw（不设则自动选 data/ 与 backend/data/ 中行数多的）
# RAW_PAGES_JSONL=D:\Agent program\RocomWiki\backend\data\raw_pages.jsonl

# ---------- .env 配置说明（哪些要设、哪些可省略）----------
# 【必填 · 对话 LLM】OPENAI_API_BASE、OPENAI_API_KEY、OPENAI_MODEL_NAME（与网关兼容的 OpenAI 风格接口）。
# 【必填 · 已有向量库】建库完成后对话需本地 data/kb/；换 EMBEDDING 模型须删 kb 重建。
# 【必填 · 爬站建库】WIKI_BASE_URL；其余 WIKI_* 有合理默认，按需改 WIKI_MODE / WIKI_MAX_PAGES 等。
# 【必填 · 向量化】EMBEDDING_MODEL_NAME 等；与 build_kb 时保持一致。
#
# 【可选 · 一般省略即可】RAG_TOP_K、RAG_TEMPERATURE、RAG_SEARCH_TYPE、RAG_QUERY_SUFFIX、RAG_USE_LEXICAL…
# 【可选 · 多轮写入 prompt 的长度】RAG_CTX_REF_*（代词/序号问句）、RAG_CTX_FACT_*（事实类），见下节。
# 【可选 · 实体时间线 LLM】ENTITY_EXTRACT_MODEL_NAME（空=沿用对话模型）、ENTITY_EXTRACT_TEMPERATURE、
#   ENTITY_EXTRACT_MAX_TURNS、ENTITY_EXTRACT_MAX_CHARS（控制抽取模型看到的对话窗口）。
# 【可选 · 指代消歧 LLM】PRONOUN_RESOLVE_MODEL_NAME、PRONOUN_RESOLVE_TEMPERATURE、PRONOUN_CTX_*、
#   PRONOUN_HISTORY_SUMMARY、PRONOUN_SUMMARY_MODEL_NAME；多实体并列检索条数 PRONOUN_MULTI_MIN_ENTITIES、
#   PRONOUN_MULTI_MAX_ENTITIES（至少 min 只才走多路检索，至多 max 只各检索一次）。
#   RAG_MULTI_ENTITY_EXTRACT_MIN：LLM 实体抽取至少几个实体才对 general/explicit 问句走「按实体分别检索」
#   （默认 2；上限沿用 PRONOUN_MULTI_MAX_ENTITIES）。
# 【可选 · 检索门控】RAG_CONTEXT_SUBJECT_GATE=true 时要求片段命中解析出的 subject。

# ---------- 向量检索（建库与对话须同一模型；改模型后必须重建 FAISS）----------
# 默认中文语义检索向量化（长期方案）
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
# cpu 或 cuda
# EMBEDDING_DEVICE=cpu
# BGE 建议 true
# EMBEDDING_NORMALIZE=true
# 个别环境需 trust_remote_code 时设为 true
# EMBEDDING_TRUST_REMOTE_CODE=false
# 无法从 Hub 下载时：把模型整包放到本地目录后，将下面改为该目录的绝对路径（与 Hub 一致的文件结构）
# EMBEDDING_MODEL_NAME=D:\models\bge-small-zh-v1.5

# RAG：检索条数、生成温度
# RAG_TOP_K=16
# RAG_TEMPERATURE=0.1
# similarity（默认）或 mmr（多样性略好，略慢）
# RAG_SEARCH_TYPE=similarity
# RAG_FETCH_K=48
# RAG_MMR_LAMBDA=0.65
# 仅在使用旧英文向量库时建议 true；BGE 下默认 false 即可
# RAG_USE_LEXICAL=false
# RAG_LEXICAL_CAP=16
# 实体抽取 / 指代消解：是否使用 LangChain with_structured_output（依赖网关支持 OpenAI 式 response_format）。
# LongCat 等若报「This response_format type is unavailable」须保持关闭（不设、false、0 均可）。
# 关闭后仍会从模型回复解析 JSON；已支持 markdown 代码块与 reasoning 字段合并解析。
# RAG_LLM_STRUCTURED_OUTPUT=false

# ---------- 多轮上下文流水线（backend/rag_pipeline/）----------
# 指代/序号类问句：历史轮数与字符上限（较大）
# RAG_CTX_REF_TURNS=8
# RAG_CTX_REF_CHARS=2800
# RAG_CTX_REF_TIMELINE_MAX=16
# 事实类问句：历史预算（较小）
# RAG_CTX_FACT_TURNS=4
# RAG_CTX_FACT_CHARS=1600
# RAG_CTX_FACT_TIMELINE_MAX=12
# 解析出主体后，要求检索片段中至少 min 条命中该主体（默认 false，设为 true 更严）
# RAG_CONTEXT_SUBJECT_GATE=false
# RAG_CONTEXT_SUBJECT_GATE_MIN=1

# 多轮实体时间线：仅用大模型抽取（每轮一次；含本轮 user_input，失败则时间线为空）
# 专用于抽取的模型（留空则与对话共用 OPENAI_MODEL_NAME，仅 temperature 可单独设）
# ENTITY_EXTRACT_MODEL_NAME=
# ENTITY_EXTRACT_TEMPERATURE=0
# 送入抽取模型的历史轮数/字符上限（正序截断后从末尾取）
# ENTITY_EXTRACT_MAX_TURNS=10
# ENTITY_EXTRACT_MAX_CHARS=4500
# 多实体对比类：LLM 输出 entities + info_type（字符串数组）后分别检索，至少几个实体才触发（默认 2）
# RAG_MULTI_ENTITY_EXTRACT_MIN=2

# ---------- 指代消解 LLM（backend/rag_pipeline/pronoun_resolve_llm.py）----------
# 当 query_resolve 判为代词句（它/该/这个…）且本 pipeline 已传入 llm 时，再调一次模型做语义消歧。
# 送入模型的对话窗口（与实体抽取类似，含本轮 user_input）：
# PRONOUN_CTX_MAX_TURNS=10
# PRONOUN_CTX_MAX_CHARS=4500
# 专用于指代模型（留空则与对话模型相同）
# PRONOUN_RESOLVE_MODEL_NAME=
# PRONOUN_RESOLVE_TEMPERATURE=0
# 是否先用 LLM 压缩对话再消歧（多一次调用，默认关）
# PRONOUN_HISTORY_SUMMARY=false
# 压缩步骤专用模型（留空则与 PRONOUN_RESOLVE / 对话模型相同）
# PRONOUN_SUMMARY_MODEL_NAME=
# 多实体并列检索：模型 action=multi_answer 且列出 ≥MIN 只时，对每只各做一次向量检索（上限 MAX，防 token/费用爆炸）
# PRONOUN_MULTI_MIN_ENTITIES=2
# PRONOUN_MULTI_MAX_ENTITIES=6

# 半自动生成评测集（backend/gen_eval_golden.py），覆盖默认 LLM temperature
# GEN_EVAL_TEMPERATURE=0.35

# RAGAS 评测（backend/eval_rag_ragas.py）单指标超时（秒）
# RAGAS_EVAL_TIMEOUT=180
# answer_relevancy 默认 strictness=1（仅 n=1 的网关必设；>1 可能 400 Invalid n value）
# RAGAS_ANSWER_RELEVANCY_STRICTNESS=1
# eval_rag_ragas 使用旧版 Metric + LangChain ChatOpenAI；评测模型建议 chat（未设置则沿用 OPENAI_MODEL_NAME）
# RAGAS_OPENAI_MODEL_NAME=deepseek-chat

# 多轮对话持久化文件路径（默认 data/conversations.json）
# CONVERSATIONS_STORE_PATH=

# ---------- 线上评估（对话结束后异步写 JSONL，不阻塞响应；非 RAGAS）----------
# ONLINE_EVAL_ENABLED=true
# 默认 data/eval/online_eval.jsonl（已加入 .gitignore）
# ONLINE_EVAL_LOG_PATH=data/eval/online_eval.jsonl
# 用 BGE 算 Q/A 向量余弦相似度，作粗 relevancy 代理（本地算，略增延迟在后台线程）
# ONLINE_EVAL_QUICK_SCORE=true
# ONLINE_EVAL_MAX_QUESTION_CHARS=2000

# Hugging Face：不设 HF_ENDPOINT 时走官方 huggingface.co（需网络可达，可配合系统代理）。
# 国内直连官方易超时可改用镜像；若连接镜像报 WinError 10060 / 超时，请删除或注释 HF_ENDPOINT，
# 换可访问的网络（代理访问官方、或换时段），或使用上面「本地目录」的 EMBEDDING_MODEL_NAME。
# （与 https://hf-mirror.com 文档一致，按需取消注释）
# HF_ENDPOINT=https://hf-mirror.com
# 嵌入模型已在本机 Hub 缓存（或 EMBEDDING_MODEL_NAME 为本地目录）时设为 true，可避免 uvicorn 启动/重载反复 HEAD 镜像超时。
# HF_EMBEDDING_OFFLINE=true
# 可选：下载阶段超时秒数（连不上主机时无效，需先解决网络/镜像）
# HF_HUB_DOWNLOAD_TIMEOUT=120
